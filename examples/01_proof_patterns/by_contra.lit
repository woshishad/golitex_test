abstract_prop p(a)

have b R, c R

know forall a R:
    $p(a + b)
    =>:
        $p(a)

know not $p(c)

by contra:
    prove:
        not $p(c + b)
    impossible $p(c)

by contra 1 = 1:
    impossible 1 != 1

by contra:
    prove:
        not exist x R st {x != x}
    have by exist x R st {x != x}: a
    impossible a = a

by contra:
    prove:
        exist x R st {x = x}
    impossible 0 = 0
