# Power builtin rules cover common exponent algebra and order patterns.
# Example shape: use the equality/order directly instead of a local `know`.

0^0 = 1

forall x Q, n, m N:
    x^n * x^m = x^(n + m)

forall x, y Q, n N:
    (x * y)^n = x^n * y^n

forall x Q, n N_pos:
    x^n = 0
    =>:
        x = 0

forall x, y Q, n N_pos:
    x >= y
    y >= 0
    =>:
        x^n >= y^n
        y^n >= 0

forall x Q, n N_pos:
    abs(x^n) = abs(x)^n

forall x Q_nz, n, m Z:
    x^n * x^m = x^(n + m)
