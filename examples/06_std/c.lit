import C

(1, 2) $in &C::C
have z &C::C = (3, 4)

&C::C{z}.re = 3
&C::C{z}.im = 4

C::add((1, 2), (3, 4)) = (1 + 3, 2 + 4) = (4, 6)
C::neg((1, 2)) = (-1 * 1, -1 * 2)
C::sub((5, 7), (2, 3)) = (5 - 2, 7 - 3) = (3, 4)
C::mul((1, 2), (3, 4)) = (1 * 3 - 2 * 4, 1 * 4 + 2 * 3) = (-5, 10)
C::conj((3, 5)) = (3, -1 * 5)

C::normSq(z) = 3^2 + 4^2 = 25
C::norm(z) = 5
C::I = (0, 1)
C::ofReal(2) = (2, 0)
