# This example shows how Lean/Mathlib-style aliases can be attached to a local
# theorem while keeping trivial builtin arithmetic facts out of std.

thm example_real_addition_commutes, add_comm:
    prove:
        forall a, b R:
            a + b = b + a
    a + b = b + a

thm example_real_zero_added_on_left, zero_add:
    prove:
        forall a R:
            0 + a = a
    0 + a = a

thm example_real_multiplication_distributes_over_addition_left, left_distrib:
    prove:
        forall a, b, c R:
            a * (b + c) = a * b + a * c
    a * (b + c) = a * b + a * c

# Litex-style names and Lean/Mathlib-style aliases both work locally.
by thm example_real_addition_commutes(2, 3)
2 + 3 = 3 + 2

by thm add_comm(2, 3)
2 + 3 = 3 + 2

by thm example_real_zero_added_on_left(5)
0 + 5 = 5

by thm zero_add(5)
0 + 5 = 5

by thm example_real_multiplication_distributes_over_addition_left(2, 3, 4)
2 * (3 + 4) = 2 * 3 + 2 * 4

by thm left_distrib(2, 3, 4)
2 * (3 + 4) = 2 * 3 + 2 * 4
