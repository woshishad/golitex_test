import Real
import Monotone

# LUB experiments for the current Real std interface.

claim:
    prove:
        forall E set, s R:
            $Real::is_least_upper_bound(E, s)
            =>:
                $Real::is_upper_bound(E, s)
    $Real::is_upper_bound(E, s)

claim:
    prove:
        forall E set, s R, x E:
            $Real::is_least_upper_bound(E, s)
            =>:
                x <= s
    $Real::is_upper_bound(E, s)
    x <= s

claim:
    prove:
        forall E set, s, M R:
            $Real::is_least_upper_bound(E, s)
            $Real::is_upper_bound(E, M)
            =>:
                s <= M
    forall B R:
        $Real::is_upper_bound(E, B)
        =>:
            s <= B
    s <= M

claim:
    prove:
        forall E set, s, t R:
            $Real::is_least_upper_bound(E, s)
            $Real::is_least_upper_bound(E, t)
            =>:
                s = t
    by thm Real::least_upper_bound_unique(E, s, t)
    s = t

claim:
    prove:
        forall E set:
            $Real::nonempty_subset(E)
            $Real::has_upper_bound(E)
            =>:
                exist s R st {$Real::is_least_upper_bound(E, s)}
    by thm Real::exists_least_upper_bound(E)
    $Real::has_least_upper_bound(E)
    exist s R st {$Real::is_least_upper_bound(E, s)}

claim:
    prove:
        forall E set, s R, epsilon R_pos:
            $Real::is_least_upper_bound(E, s)
            =>:
                exist x E st {s - epsilon < x}
    by thm Real::least_upper_bound_member_above_of_lt(E, s, epsilon)
    exist x E st {s - epsilon < x}

claim:
    prove:
        forall E set, s, y R:
            $Real::is_least_upper_bound(E, s)
            y < s
            =>:
                exist x E st {y < x}
    s - y > 0
    s - y $in R_pos
    by thm Real::least_upper_bound_member_above_of_lt(E, s, s - y)
    have by exist x E st {s - (s - y) < x}: x
    s - (s - y) = y
    y < x
    witness exist x E st {y < x} from x:
        y < x

claim:
    prove:
        forall E set, s, y R:
            $Real::is_least_upper_bound(E, s)
            y < s
            =>:
                exist x E st {y < x and x <= s}
    s - y > 0
    s - y $in R_pos
    by thm Real::least_upper_bound_member_above_of_lt(E, s, s - y)
    have by exist x E st {s - (s - y) < x}: x
    s - (s - y) = y
    y < x
    $Real::is_upper_bound(E, s)
    x <= s
    witness exist x E st {y < x and x <= s} from x:
        y < x and x <= s

claim:
    prove:
        forall E set, s, x R:
            $Real::is_least_upper_bound(E, s)
            x $in E
            =>:
                x <= s
    $Real::is_upper_bound(E, s)
    x <= s

claim:
    prove:
        forall a seq(R), s R, n N_pos:
            $Real::is_least_upper_bound(fn_range(a), s)
            =>:
                a(n) <= s
    a(n) $in fn_range(a)
    $Real::is_upper_bound(fn_range(a), s)
    a(n) <= s

claim:
    prove:
        forall u, s R, epsilon R_pos:
            s - epsilon < u
            u <= s
            =>:
                abs(u - s) < epsilon
    0 < epsilon
    u - s <= 0
    u - s < epsilon
    -(u - s) = s - u
    u - (s - epsilon) > 0
    u - (s - epsilon) = u - s + epsilon
    u - s + epsilon > 0
    u - s + epsilon = epsilon - (s - u)
    epsilon - (s - u) > 0
    epsilon > s - u
    s - u < epsilon
    -(u - s) < epsilon
    abs(u - s) < epsilon

claim:
    prove:
        forall a seq(R), s R:
            $Real::is_least_upper_bound(fn_range(a), s)
            forall m, n N_pos:
                n >= m
                =>:
                    a(m) <= a(n)
            =>:
                $Real::seq_converges(a, s)
    claim:
        prove:
            forall epsilon R_pos:
                exist n0 N_pos st {$Real::seq_tail_close(a, s, epsilon, n0)}
        by thm Real::least_upper_bound_member_above_of_lt(fn_range(a), s, epsilon)
        have by exist x fn_range(a) st {s - epsilon < x}: x
        have by preimage m from x $in fn_range(a)
        witness exist n0 N_pos st {$Real::seq_tail_close(a, s, epsilon, n0)} from m:
            forall n N_pos:
                n >= m
                =>:
                    x = a(m)
                    s - epsilon < a(m)
                    a(m) <= a(n)
                    a(n) - a(m) >= 0
                    a(m) - (s - epsilon) > 0
                    a(n) - (s - epsilon) = (a(n) - a(m)) + (a(m) - (s - epsilon))
                    (a(n) - a(m)) + (a(m) - (s - epsilon)) > 0
                    a(n) - (s - epsilon) > 0
                    s - epsilon < a(n)
                    a(n) $in fn_range(a)
                    $Real::is_upper_bound(fn_range(a), s)
                    a(n) <= s
                    abs(a(n) - s) < epsilon
            $Real::seq_tail_close(a, s, epsilon, m)
        exist n0 N_pos st {$Real::seq_tail_close(a, s, epsilon, n0)}
    $Real::seq_converges(a, s)

prop increasing_to_index(a seq(R), n N_pos):
    forall m N_pos:
        m <= n
        =>:
            a(m) <= a(n)

claim:
    prove:
        forall a seq(R), m, n N_pos:
            $Monotone::increasing_seq(a)
            n >= m
            =>:
                a(m) <= a(n)
    by induc n from 1:
        prove:
            $increasing_to_index(a, n)
        prove from n = 1:
            forall k N_pos:
                k <= 1
                =>:
                    k = 1
                    a(k) = a(1)
                    a(k) <= a(1)
            $increasing_to_index(a, 1)
        prove induc:
            claim:
                prove:
                    forall k N_pos:
                        k <= n + 1
                        =>:
                            a(k) <= a(n + 1)
                k <= n or k >= n + 1
                by cases:
                    prove:
                        a(k) <= a(n + 1)
                    case k <= n:
                        a(k) <= a(n)
                        a(n) <= a(n + 1)
                        a(k) <= a(n) <= a(n + 1)
                        a(k) <= a(n + 1)
                    case k >= n + 1:
                        k = n + 1
                        a(k) = a(n + 1)
                        a(k) <= a(n + 1)
            $increasing_to_index(a, n + 1)
    m <= n
    $increasing_to_index(a, n)
    a(m) <= a(n)

claim:
    prove:
        forall a seq(R):
            $Real::nonempty_subset(fn_range(a))
    fn_range(a) $subset R
    a(1) $in fn_range(a)
    witness $is_nonempty_set(fn_range(a)) from a(1):
        a(1) $in fn_range(a)
    $Real::nonempty_subset(fn_range(a))

claim:
    prove:
        forall a seq(R):
            $Monotone::bounded_above_seq(a)
            =>:
                $Real::has_upper_bound(fn_range(a))
    have by exist M R st {$Monotone::is_seq_upper_bound(a, M)}: M
    claim:
        prove:
            forall x fn_range(a):
                x <= M
        have by preimage n from x $in fn_range(a)
        x = a(n)
        a(n) <= M
        x <= M
    $Real::is_upper_bound(fn_range(a), M)
    witness exist B R st {$Real::is_upper_bound(fn_range(a), B)} from M:
        $Real::is_upper_bound(fn_range(a), M)
    $Real::has_upper_bound(fn_range(a))

claim:
    prove:
        forall a seq(R):
            $Monotone::bounded_above_seq(a)
            =>:
                exist s R st {$Real::is_least_upper_bound(fn_range(a), s)}
    fn_range(a) $subset R
    a(1) $in fn_range(a)
    witness $is_nonempty_set(fn_range(a)) from a(1):
        a(1) $in fn_range(a)
    $Real::nonempty_subset(fn_range(a))
    $Real::has_upper_bound(fn_range(a))
    by thm Real::exists_least_upper_bound(fn_range(a))
    $Real::has_least_upper_bound(fn_range(a))
    exist s R st {$Real::is_least_upper_bound(fn_range(a), s)}

claim:
    prove:
        forall a seq(R):
            $Monotone::increasing_seq(a)
            $Monotone::bounded_above_seq(a)
            =>:
                $Real::convergent_seq(a)
    fn_range(a) $subset R
    a(1) $in fn_range(a)
    witness $is_nonempty_set(fn_range(a)) from a(1):
        a(1) $in fn_range(a)
    $Real::nonempty_subset(fn_range(a))
    $Real::has_upper_bound(fn_range(a))
    by thm Real::exists_least_upper_bound(fn_range(a))
    $Real::has_least_upper_bound(fn_range(a))
    have by exist s R st {$Real::is_least_upper_bound(fn_range(a), s)}: s
    claim:
        prove:
            forall m, n N_pos:
                n >= m
                =>:
                    a(m) <= a(n)
        a(m) <= a(n)
    claim:
        prove:
            forall epsilon R_pos:
                exist n0 N_pos st {$Real::seq_tail_close(a, s, epsilon, n0)}
        by thm Real::least_upper_bound_member_above_of_lt(fn_range(a), s, epsilon)
        have by exist x fn_range(a) st {s - epsilon < x}: x
        have by preimage m from x $in fn_range(a)
        witness exist n0 N_pos st {$Real::seq_tail_close(a, s, epsilon, n0)} from m:
            forall n N_pos:
                n >= m
                =>:
                    x = a(m)
                    s - epsilon < a(m)
                    a(m) <= a(n)
                    a(n) - a(m) >= 0
                    a(m) - (s - epsilon) > 0
                    a(n) - (s - epsilon) = (a(n) - a(m)) + (a(m) - (s - epsilon))
                    (a(n) - a(m)) + (a(m) - (s - epsilon)) > 0
                    a(n) - (s - epsilon) > 0
                    s - epsilon < a(n)
                    a(n) $in fn_range(a)
                    $Real::is_upper_bound(fn_range(a), s)
                    a(n) <= s
                    abs(a(n) - s) < epsilon
            $Real::seq_tail_close(a, s, epsilon, m)
        exist n0 N_pos st {$Real::seq_tail_close(a, s, epsilon, n0)}
    $Real::seq_converges(a, s)
    witness exist x R st {$Real::seq_converges(a, x)} from s:
        $Real::seq_converges(a, s)
    $Real::convergent_seq(a)
