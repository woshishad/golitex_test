prove:
    let a, b set:
        a $subset b
    forall x a:
        x $in b
    b $superset a

prove:
    let a, b set:
        not a $subset b
    not b $superset a

prove:
    let A, B set:
        forall x A:
            $in(x, B)

    forall x A:
        $in(x, B)

    A $subset B
    B $superset A

prove:
    not $is_nonempty_set({})

prove:
    not 4 $in {1, 2, 3}

prove:
    have x Z = 4
    x != 1
    x != 2
    x != 3
    not x $in {1, 2, 3}
